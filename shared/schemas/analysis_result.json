{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://vigilyx.io/schemas/analysis_result.json",
  "title": "AnalysisResult",
  "description": "AI analysis result data model",
  "type": "object",
  "required": ["session_id", "threat_level", "confidence", "summary", "analyzed_at"],
  "properties": {
    "session_id": {
      "type": "string",
      "format": "uuid",
      "description": "Associated session ID"
    },
    "threat_level": {
      "type": "string",
      "enum": ["safe", "low", "medium", "high", "critical"],
      "description": "Threat level"
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "Confidence score"
    },
    "categories": {
      "type": "array",
      "items": { "type": "string" },
      "default": [],
      "description": "List of threat categories"
    },
    "summary": {
      "type": "string",
      "description": "Analysis summary"
    },
    "details": {
      "type": "object",
      "additionalProperties": true,
      "default": {},
      "description": "Detailed analysis information"
    },
    "recommendations": {
      "type": "array",
      "items": { "type": "string" },
      "default": [],
      "description": "Recommended actions"
    },
    "analyzed_at": {
      "type": "string",
      "format": "date-time",
      "description": "Analysis timestamp"
    }
  }
}
