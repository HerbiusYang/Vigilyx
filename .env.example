# ============================================
# Vigilyx environment configuration (shared by local development and Docker deployment)
# ============================================
#
# Docker deployment:
#   Preferred path (run from project root):
#     bash scripts/generate-secrets.sh
#   Manual template path:
#     cd deploy/docker && cp .env.example .env
#     vi .env   # replace every <CHANGE_ME> with strong random values
#     chmod 600 .env
#
# Local development (without Docker):
#   cp .env.example .env
#   Fill values according to the notes below
#
# ============================================

# -- Database --
# PostgreSQL for Docker deployment:
# DATABASE_URL=postgres://vigilyx:<password>@localhost:5433/vigilyx
# PG_USER=vigilyx
# PG_PASSWORD=<CHANGE_ME>
# PG_DB=vigilyx

# ── Redis ──
# REDIS_URL=redis://:${REDIS_PASSWORD}@127.0.0.1:6379
# REDIS_PASSWORD=<CHANGE_ME>

# -- API authentication (required) --
# JWT signing key (at least 32 characters)
# Generate with: openssl rand -hex 32
# API_JWT_SECRET=<CHANGE_ME>

# Admin password (the system will force a change after first login)
# Generate with: openssl rand -hex 16
# API_PASSWORD=<CHANGE_ME>

# API_USERNAME=admin                 # Admin username (default: admin)
# API_TOKEN_EXPIRE_HOURS=24          # JWT expiration time (default: 24 hours)

# -- Inter-service authentication --
# Internal component auth token (sniffer/engine <-> API)
# Generate with: openssl rand -hex 24
# INTERNAL_API_TOKEN=<CHANGE_ME>
# Dedicated AI service token (API/engine -> AI); must differ from INTERNAL_API_TOKEN
# AI_INTERNAL_TOKEN=<CHANGE_ME_DIFFERENT_FROM_INTERNAL_API_TOKEN>

# -- Network capture --
# Timezone used by the API when reporting "server time" to the UI.
# SERVER_TIMEZONE=Asia/Shanghai
# Network interface (macOS: en0, Linux: eth0/ens33)
SNIFFER_INTERFACE=en0
SNIFFER_PROMISCUOUS=true

# Mail protocol ports
SMTP_PORTS=25,465,587,2525,2526
POP3_PORTS=110,995
IMAP_PORTS=143,993
# HTTP_PORTS=80,443,8080             # Required by the data-security feature

# -- API service --
API_HOST=127.0.0.1
API_PORT=8088

# -- AI service (optional) --
AI_ENABLED=false
AI_SERVICE_URL=http://127.0.0.1:8900
# HF_ENDPOINT=https://hf-mirror.com  # HuggingFace mirror (mainland China)

# -- Logging --
# Do not use debug logging in production (sniffer CPU cost becomes extreme)
RUST_LOG=info,vigilyx_api=info,vigilyx_engine=info
