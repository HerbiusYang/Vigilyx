# ============================================
# Vigilyx Docker deployment environment configuration
# ============================================
#
# First deployment:
#   Recommended:
#   1. From the project root, run: bash scripts/generate-secrets.sh
#   2. Review and adjust deploy/docker/.env
#
#   Manual template flow:
#   1. cp .env.example .env
#   2. Replace every <CHANGE_ME> below with strong random values
#   3. chmod 600 .env
#
# !! Security warning !!
#   - The .env file contains sensitive credentials and must never be committed to git
#   - Every <CHANGE_ME> must be replaced or the service will refuse to start
#   - Do not use sample values or weak passwords in production
#   - Prefer generate-secrets.sh to create cryptographically secure random values automatically
#
# ============================================

# -- Database (PostgreSQL) --
PG_USER=vigilyx
PG_PASSWORD=<CHANGE_ME>
PG_DB=vigilyx
# PG_PORT=5433                       # PostgreSQL external mapped port (default: 5433)

# ── Redis ──
REDIS_PASSWORD=<CHANGE_ME>
# REDIS_PORT=6379                    # Redis external mapped port (default: 6379)

# -- API authentication --
# JWT signing key (at least 32 chars; 64 hex chars recommended)
API_JWT_SECRET=<CHANGE_ME>
# Initial admin password (the system forces a change after first login)
# Must be set explicitly. The service refuses to start if unset, unless VIGILYX_ALLOW_DEFAULT_CREDS=true is also set
API_PASSWORD=<CHANGE_ME>
# VIGILYX_ALLOW_DEFAULT_CREDS=false  # Set to true only in development to allow the default password admin123
# API_USERNAME=admin                 # Admin username (default: admin)
# API_TOKEN_EXPIRE_HOURS=24          # JWT expiration time (default: 24 hours)
# API_LISTEN=127.0.0.1               # Listen on localhost by default; change to 0.0.0.0 only for temporary non-TLS external testing
# API_PORT=8088                      # API external mapped port (default: 8088)
# TRUSTED_PROXY_IPS=127.0.0.1,::1    # Local reverse proxies are trusted by default; keep these and append any extra LB/WAF IPs
# TRUSTED_PROXY_HOSTS=localhost,host.docker.internal,caddy,vigilyx-caddy
#                                   # Host/Compose Caddy is already covered by default; preserve these defaults when adding custom proxies

# -- Inter-service authentication --
# Internal component auth token (sniffer/engine <-> API)
INTERNAL_API_TOKEN=<CHANGE_ME>
# Dedicated AI service token (API/engine -> AI / VT scrape); must differ from INTERNAL_API_TOKEN
AI_INTERNAL_TOKEN=<CHANGE_ME_DIFFERENT_FROM_INTERNAL_API_TOKEN>

# -- Network capture --
# Network interface (adjust to your environment: common Linux values are eth0/ens33, macOS uses en0)
SNIFFER_INTERFACE=eth0
# SNIFFER_PROMISCUOUS=true           # Promiscuous mode (default: true)
# SNIFFER_CAPTURE_BUFFER_MB=256      # libpcap capture buffer in MB; raise further on very bursty mirror traffic
# SMTP_PORTS=25,465,587,2525,2526    # SMTP ports (defaults already include common ports)
# POP3_PORTS=110,995                 # POP3 ports
# IMAP_PORTS=143,993                 # IMAP ports
# HTTP_PORTS=80,443,8080             # HTTP ports (required by the data-security feature)

# -- MTA proxy mode (requires docker compose --profile mta) --
# Vigilyx MTA currently acts as an inbound MX security proxy and accepts mail only for local domains.
# MTA_LOCAL_DOMAINS must list your real recipient domains, comma-separated; leaving it empty causes all RCPT TO commands to be rejected.
# MTA_LOCAL_DOMAINS=example.com,example.org
# MTA_DOWNSTREAM_HOST=10.0.0.25      # Downstream real MTA / mail-gateway address
# MTA_DOWNSTREAM_PORT=25
# MTA_DOWNSTREAM_STARTTLS=false
# MTA_INLINE_TIMEOUT_SECS=8
# MTA_FAIL_OPEN=false                # false (default) = return 451 on engine failure; true = keep relaying (with a missed-scan risk)
# MTA_SMTP_PORT=25
# MTA_SMTPS_PORT=465
# MTA_HOSTNAME=mx1.example.com
# MTA_LISTEN: host-side port bind address (left side of docker-compose ports), controlling which NICs expose SMTP
# MTA_LISTEN=0.0.0.0               # Default: all NICs. Production should usually restrict this to an internal IP
# MTA_LISTEN_HOST: in-container bind address for the MTA process; usually no change is needed
# MTA_LISTEN_HOST=0.0.0.0          # Default: all interfaces inside the container
# Keep 587 submission closed until SMTP AUTH is implemented; do not expose it additionally

# -- AI service (optional, requires --profile ai) --
AI_ENABLED=false
# HuggingFace endpoint (mainland China users should uncomment the mirror)
# HF_ENDPOINT=https://hf-mirror.com
# VIGILYX_NUM_THREADS=32             # AI inference thread count (default: CPU cores x 0.7)

# -- Logging --
# RUST_LOG=info,vigilyx_api=info,vigilyx_engine=info
# RUST_LOG_SNIFFER=info,vigilyx_sniffer=info
# Do not use debug logging in production (CPU overhead becomes extreme)

# -- TLS (in production, using host Caddy/Nginx is recommended; see docs/DEPLOYMENT.md) --
# The variables below are only for the built-in Caddy / ./deploy.sh --tls bootstrap flow
# Domain -> auto-request certificates by default; IP/localhost -> fall back to Caddy internal CA by default
# VIGILYX_DOMAIN=vigilyx.example.com
# VIGILYX_DOMAIN=192.0.2.10
# CADDY_TLS_MODE=auto                # Optional override: auto | internal | files
# CADDY_ACME_EMAIL=ops@example.com   # Recommended in auto mode so certificate notices have a recipient
# VIGILYX_TLS_CERT_FILE=/data/vigilyx.crt
# VIGILYX_TLS_KEY_FILE=/data/vigilyx.key

# -- Advanced options --
# PORTAL_MODE=false                  # Portal mode: redirect / to /portal
# API_CORS_ORIGINS=                  # Allowed CORS origins (comma-separated; * is for development only)
# FRONTEND_DIST=../../frontend/dist  # Only for docker-compose.dev.yml to override local frontend assets
# CLAMAV_ENABLED=false               # Enable ClamAV modules and have deploy.sh auto-start the antivirus profile
# CLAMAV_HOST=clamav                 # ClamAV address (requires --profile antivirus)
# CLAMAV_PORT=3310                   # ClamAV port
# SANDBOX_URL=http://sandbox:8000    # CAPEv2 sandbox URL (experimental, requires --profile sandbox)
# SANDBOX_API_TOKEN=                 # CAPEv2 API token
# SANDBOX_TIMEOUT_SECS=300           # Sandbox analysis timeout
