# ═══════════════════════════════════════════════════
# Vigilyx AI Service Dockerfile
# Python NLP phishing detection + LLM analysis + intel scraping
# ═══════════════════════════════════════════════════
#
# Includes:
#   - HuggingFace mDeBERTa NLP models (zero-shot + fine-tuned)
#   - Claude/OpenAI LLM calls (mail-content analysis)
#   - Playwright Chromium (VirusTotal page scraping)
#   - FastAPI HTTP service (called by the Rust engine)
#
# Model cache strategy:
#   - Base HuggingFace models are cached in /app/.hf_cache (persisted via a mounted volume)
#   - Fine-tuned models are stored in /app/data/nlp_models/ (shared volume with the main service)
#
# Build:
#   docker build -f deploy/docker/Dockerfile.ai -t vigilyx-ai:latest .
#
# Run:
#   docker run -d --name vigilyx-ai \
#     -p 8900:8900 \
#     -v vigilyx_data:/app/data \
#     -v vigilyx_hf_cache:/app/.hf_cache \
#     -e HF_HOME=/app/.hf_cache \
#     vigilyx-ai:latest

FROM python:3.12-slim-bookworm AS base

WORKDIR /app

# -- System dependencies --
# Playwright Chromium runtime libraries + curl for health checks
# Some scientific-computing dependencies may fall back to source builds under Python 3.12, so keep a minimal toolchain to avoid remote build failures.
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential gcc g++ \
    libnss3 libnspr4 libdbus-1-3 libatk1.0-0 libatk-bridge2.0-0 \
    libcups2 libdrm2 libxkbcommon0 libxcomposite1 libxdamage1 \
    libxfixes3 libxrandr2 libgbm1 libpango-1.0-0 libcairo2 \
    libasound2 libatspi2.0-0 \
    curl \
    && rm -rf /var/lib/apt/lists/*

# -- Python dependencies (make use of Docker layer cache) --
# pyproject.toml already pins top-level dependencies and the hatchling build backend precisely to avoid remote build drift.
# Copy pyproject.toml first and create a minimal package skeleton before installing dependencies
COPY python/pyproject.toml ./
RUN mkdir -p vigilyx_ai && touch vigilyx_ai/__init__.py \
    && pip install --no-cache-dir . \
    && pip check \
    && rm -rf vigilyx_ai

# ── Playwright Chromium ──
ENV PLAYWRIGHT_BROWSERS_PATH=/app/.browsers
RUN playwright install chromium

# -- Application code (overwrites the earlier stub) --
COPY python/vigilyx_ai ./vigilyx_ai

# -- Data directory --
# data/nlp_models/ stores fine-tuned models (shared volume with the main service)
RUN mkdir -p /app/data/nlp_models

# SEC-C01: run as a non-root user (CWE-250)
RUN groupadd -r vigilyx && useradd -r -g vigilyx -d /app vigilyx \
    && chown -R vigilyx:vigilyx /app
USER vigilyx

# -- Environment variables --
ENV PYTHONUNBUFFERED=1 \
    HF_HOME=/app/.hf_cache \
    HF_ENDPOINT=https://huggingface.co \
    VIGILYX_NUM_THREADS=4

EXPOSE 8900

# -- Health check --
HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD curl -sf http://127.0.0.1:8900/health || exit 1

CMD ["uvicorn", "vigilyx_ai.api:app", "--host", "0.0.0.0", "--port", "8900"]
